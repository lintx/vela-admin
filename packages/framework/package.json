{
  "name": "vela-admin",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lintx/vela-admin",
    "directory": "packages/framework"
  },
  "bugs": {
    "url": "https://github.com/lintx/vela-admin/issues"
  },
  "homepage": "https://github.com/lintx/vela-admin#readme",
  "keywords": [
    "vue",
    "admin",
    "varlet",
    "material-design",
    "vite"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./app": {
      "types": "./src/app/index.ts",
      "import": "./src/app/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./icons": {
      "types": "./src/icons/index.ts",
      "import": "./src/icons/index.ts"
    },
    "./layout": {
      "types": "./src/layout/index.ts",
      "import": "./src/layout/index.ts"
    },
    "./menu": {
      "types": "./src/menu/index.ts",
      "import": "./src/menu/index.ts"
    },
    "./permission": {
      "types": "./src/permission/index.ts",
      "import": "./src/permission/index.ts"
    },
    "./router": {
      "types": "./src/router/index.ts",
      "import": "./src/router/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    },
    "./tabs": {
      "types": "./src/tabs/index.ts",
      "import": "./src/tabs/index.ts"
    },
    "./style": "./styles/index.css"
  },
  "sideEffects": [
    "./styles/**/*.css",
    "**/*.css"
  ],
  "files": [
    "README.md",
    "src",
    "styles"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "vite build"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0",
    "@phosphor-icons/vue": "^2.2.1",
    "@tabler/icons-vue": "^3.44.0",
    "@varlet/ui": "^3.10.7",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.4",
    "vitest": "^3.2.4",
    "vue-router": "^4.5.1"
  }
}
